{
	"mcpServers": {
		"risingwave-mcp": {
			"type": "stdio",
			"command": "uv",
			"args": [
				"run",
				"python",
				"src/main.py"
			],
			"cwd": "/home/savas/risingwave-mcp",
			"env": {
				"RISINGWAVE_CONNECTION_STR": "postgresql://root:root@localhost:4566/dev"
			},
			"disabled": false,
			"alwaysAllow": [
				"show_tables",
				"describe_table",
				"create_materialized_view",
				"describe_materialized_view",
				"run_select_query",
				"list_materialized_views",
				"table_row_count",
				"drop_materialized_view"
			]
		}
	}
}