                "value": "14-Day Real Bet"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "customer_id"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "displayName",
                "value": "Customer ID"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "currency_id"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Currency"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "event_ts"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Last Event"
              },
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "risingwave-sql"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawCode": true,
          "refId": "A",
          "rawSql": "SELECT customer_id, currency_id, rolling_14d_real_bet_amount, event_ts FROM (   SELECT customer_id, currency_id, rolling_14d_real_bet_amount, event_ts,          ROW_NUMBER() OVER (PARTITION BY customer_id, currency_id ORDER BY event_ts DESC) AS rn   FROM mv_casino_real_bet ) t WHERE rn = 1 ORDER BY event_ts DESC NULLS LAST LIMIT 20"
        }
      ]
    },
