          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (sink_name) (rate(sink_commit_duration_count{sink_name=~\".*casino.*|.*turnover.*\"}[5m]) * 60)",
          "legendFormat": "{{sink_name}}",
          "refId": "A"
        }
      ]
    },
