    {
      "id": 23,
      "type": "timeseries",
      "title": "Iceberg Sink Commits / min",
      "description": "Checkpoint commit rate for the two Iceberg upsert sinks. Each commit corresponds to the ~5s checkpoint interval (~12 commits/min). Spiky pattern is normal \u2014 RisingWave batches writes per checkpoint.",
      "datasource": {
