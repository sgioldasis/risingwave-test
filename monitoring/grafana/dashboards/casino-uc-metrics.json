    {
      "id": 21,
      "type": "timeseries",
      "title": "Kafka Sink Throughput (rows/s)",
      "description": "Input row rate for the two Kafka output sinks. After backfill, reflects the live production event rate. Used for PoC R4 latency benchmark \u2014 higher TPS = more meaningful p95 measurement.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rowsps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (sink_name) (\n  rate(stream_sink_input_row_count[5m])\n  * on (sink_id) group_left(sink_name)\n    max by (sink_id, sink_name) (sink_info{sink_name=~\".*kafka.*\"})\n)",
          "legendFormat": "{{sink_name}}",
          "refId": "A"
        }
      ]
    },
    {
