    {
      "id": 5,
      "type": "stat",
      "title": "Total Real Bet Volume (14d rolling)",
      "description": "Sum of all rolling_14d_real_bet_amount across all latest customer rows \u2014 indicates total exposure.",
      "datasource": {
        "type": "postgres",
        "uid": "risingwave-sql"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "risingwave-sql"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawCode": true,
          "refId": "A",
          "rawSql": "SELECT SUM(rolling_14d_real_bet_amount)::float AS total_volume FROM (SELECT DISTINCT ON (customer_id, currency_id) customer_id, currency_id, rolling_14d_real_bet_amount FROM mv_casino_real_bet ORDER BY customer_id, currency_id, event_ts DESC) t"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Most Recently Active Customers \u2014 14-Day Real Bet Amount (UC1)",
      "description": "Most recently active customers with their current rolling 14-day real bet total. Sorted by last event time descending.",
      "datasource": {
        "type": "postgres",
        "uid": "risingwave-sql"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Event",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "rolling_14d_real_bet_amount"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
